# Postgres
POSTGRES_DB=agility_portal
POSTGRES_USER=agility
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://agility:change-me@db:5432/agility_portal

# NextAuth
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Shared secrets between frontend and backend
BACKEND_JWT_SECRET=change-me
INTERNAL_SERVICE_SECRET=change-me

# Frontend -> backend (browser-facing; must be reachable from the user's browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Frontend server -> backend (server-to-server inside the docker network, used by NextAuth callbacks)
API_INTERNAL_URL=http://backend:8000

# Backend
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
# Used to build links (e.g. contract accept links) inside outgoing emails
FRONTEND_BASE_URL=http://localhost:3000

# Frontend: mirrors ENVIRONMENT, gates the dev-login form (client-side, so must be NEXT_PUBLIC_)
NEXT_PUBLIC_ENVIRONMENT=development
